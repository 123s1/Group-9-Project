# Normalize line endings to LF on checkin
* text=auto eol=lf

# Kotlin / Java
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf

# Frontend
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.wxml text eol=lf
*.wxss text eol=lf
*.less text eol=lf
*.css text eol=lf

# Configs
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jks binary
*.keystore binary
*.apk binary
