<view class="container">
    <view class="login-box">
        <!-- Logo 区域 -->
        <view class="logo-area">
            <view class="logo-wrapper">
                <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
                <view class="logo-glow"></view>
            </view>
            <text class="app-name">安心接送</text>
            <text class="slogan">专业儿童接送服务</text>
        </view>

        <!-- 登录方式切换 -->
        <view class="login-tabs">
            <view
                    class="tab-item {{loginType === 'sms' ? 'active' : ''}}"
                    bindtap="switchLoginType"
                    data-type="sms"
            >
                验证码登录
            </view>
            <view class="tab-divider"></view>
            <view
                    class="tab-item {{loginType === 'password' ? 'active' : ''}}"
                    bindtap="switchLoginType"
                    data-type="password"
            >
                密码登录
            </view>
        </view>

        <!-- 表单区域 -->
        <view class="form-area">
            <!-- 手机号输入 -->
            <view class="input-group">
                <view class="input-label">手机号</view>
                <input
                        class="input-field {{errors.phone ? 'error' : ''}}"
                        type="number"
                        placeholder="请输入手机号"
                        maxlength="11"
                        value="{{phoneNumber}}"
                        bindinput="onPhoneInput"
                />
                <view class="error-tip" wx:if="{{errors.phone}}">{{errors.phone}}</view>
            </view>

            <!-- 验证码登录 -->
            <view class="login-pwd-form" wx:if="{{loginType === 'sms'}}">
                <view class="input-group">
                    <view class="input-label">验证码</view>
                    <view class="code-wrapper">
                        <input
                                class="input-field code-input {{errors.code ? 'error' : ''}}"
                                type="number"
                                placeholder="请输入验证码"
                                maxlength="6"
                                value="{{verifyCode}}"
                                bindinput="onCodeInput"
                        />
                        <button
                                class="get-code-btn {{countdown > 0 ? 'disabled' : ''}}"
                                bindtap="getVerifyCode"
                                disabled="{{countdown > 0}}"
                        >
                            {{countdown > 0 ? countdown + '秒' : '获取验证码'}}
                        </button>
                    </view>
                    <view class="error-tip" wx:if="{{errors.code}}">{{errors.code}}</view>
                </view>
            </view>

            <!-- 密码登录 -->
            <view class="login-pwd-form" wx:if="{{loginType === 'password'}}">
                <view class="input-group">
                    <view class="input-label">密码</view>
                    <view class="pwd-wrapper">
                        <input
                                class="input-field {{errors.password ? 'error' : ''}}"
                                type="text"
                                password="{{!showPassword}}"
                                placeholder="请输入密码 (6-20位)"
                                maxlength="20"
                                value="{{password}}"
                                bindinput="onPasswordInput"
                        />
                        <view class="pwd-toggle" bindtap="togglePassword">
                            <text class="iconfont {{showPassword ? 'icon-eye' : 'icon-eye-close'}}">
                                {{showPassword ? '👁' : '👁‍🗨'}}
                            </text>
                        </view>
                    </view>
                    <view class="error-tip" wx:if="{{errors.password}}">{{errors.password}}</view>
                </view>

                <view class="forgot-pwd">
                    <text bindtap="onForgotPassword">忘记密码？</text>
                </view>
            </view>
        </view>

        <!-- 用户协议 -->
        <view class="agreement">
            <view class="agree-wrapper" bindtap="toggleAgreement">
                <view class="checkbox {{agree ? 'checked' : ''}}">
                    <view class="check-icon" wx:if="{{agree}}">✓</view>
                </view>
                <text class="agree-text">我已阅读并同意</text>
            </view>
            <view class="links">
                <text class="link" bindtap="showUserAgreement">《用户协议》</text>
                <text class="link" bindtap="showPrivacyPolicy">《隐私政策》</text>
            </view>
        </view>

        <!-- 登录按钮 -->
        <button
                class="login-btn {{canLogin?'':'disabled'}}"
                bindtap="handleLogin"
                disabled="{{!canLogin || loading}}"
        >
            <view class="btn-content" wx:if="{{!loading}}">
                <text>登 录</text>
            </view>
            <view class="btn-loading" wx:if="{{loading}}">
                <view class="spinner"></view>
                <text>登录中...</text>
            </view>
        </button>

        <!-- 第三方登录 -->
        <view class="other-login">
            <view class="divider">
                <view class="line"></view>
                <text class="divider-text">其他登录方式</text>
                <view class="line"></view>
            </view>
            <view class="other-icons">
                <view class="icon-item" bindtap="wechatLogin">
                    <view class="icon-wrapper wechat">
                        <image class="icon" src="/images/wechat.png" mode="aspectFit"></image>
                    </view>
                    <text>微信</text>
                </view>
            </view>
        </view>
    </view>

    <!-- 底部装饰 -->
    <view class="bottom-decoration">
        <view class="wave wave1"></view>
        <view class="wave wave2"></view>
    </view>
</view>
