<view class="container">
    <!-- 用户信息卡片 -->
    <view class="user-card">
        <view class="user-info" bindtap="editProfile">
            <image class="avatar" src="{{avatar}}" mode="aspectFill"></image>
            <view class="info">
                <text class="nickname">{{nickname}}</text>
                <text class="phone">{{phone}}</text>
            </view>
            <text class="edit-icon">›</text>
        </view>

        <!-- 会员等级 -->
        <view class="member-level" bindtap="goToMember">
            <view class="level-info">
                <text class="level-name">{{memberLevelName}}</text>
                <text class="level-desc">累计消费{{formattedTotalConsumption}}</text>
            </view>
            <view class="level-progress">
                <view class="progress-bar" style="width: {{memberProgress}}%;"></view>
            </view>
            <text class="next-level">距{{nextLevelName}}还差{{nextLevelAmount}}元</text>
        </view>
    </view>

    <!-- 订单统计 -->
    <view class="stats-card">
        <view class="stat-item" bindtap="goToOrders" data-status="processing">
            <text class="stat-number">{{processingCount}}</text>
            <text class="stat-label">进行中</text>
        </view>
        <view class="stat-item" bindtap="goToOrders" data-status="completed">
            <text class="stat-number">{{completedCount}}</text>
            <text class="stat-label">已完成</text>
        </view>
        <view class="stat-item" bindtap="goToOrders" data-status="cancelled">
            <text class="stat-number">{{cancelledCount}}</text>
            <text class="stat-label">已取消</text>
        </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-card">
        <!-- 孩子管理 -->
        <view class="menu-item" bindtap="goToChildren">
            <view class="menu-left">
                <text class="menu-icon">👶</text>
                <text class="menu-title">孩子管理</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>

        <!-- 我的钱包 -->
        <view class="menu-item" bindtap="goToWallet">
            <view class="menu-left">
                <text class="menu-icon">💰</text>
                <text class="menu-title">我的钱包</text>
            </view>
            <view class="menu-right">
                <text class="menu-value">{{formattedBalance}}</text>
                <text class="menu-arrow">›</text>
            </view>
        </view>

        <!-- 优惠券 -->
        <view class="menu-item" bindtap="goToCoupons">
            <view class="menu-left">
                <text class="menu-icon">🎫</text>
                <text class="menu-title">优惠券</text>
            </view>
            <view class="menu-right">
                <text class="menu-value">{{couponCount}}张</text>
                <text class="menu-arrow">›</text>
            </view>
        </view>

        <!-- 套餐中心 -->
        <view class="menu-item" bindtap="goToPackages">
            <view class="menu-left">
                <text class="menu-icon">📦</text>
                <text class="menu-title">套餐中心</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>

        <!-- 收货地址 -->
        <view class="menu-item" bindtap="goToAddress">
            <view class="menu-left">
                <text class="menu-icon">📍</text>
                <text class="menu-title">收货地址</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>

        <!-- 发票管理 -->
        <view class="menu-item" bindtap="goToInvoice">
            <view class="menu-left">
                <text class="menu-icon">🧾</text>
                <text class="menu-title">发票管理</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>
    </view>

    <!-- 其他功能 -->
    <view class="menu-card">
        <!-- 安心日记 -->
        <view class="menu-item" bindtap="goToDiary">
            <view class="menu-left">
                <text class="menu-icon">📹</text>
                <text class="menu-title">安心日记</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>

        <!-- 支付页面 -->
        <view class="menu-item" bindtap="goToPayment">
            <view class="menu-left">
                <text class="menu-icon">💳</text>
                <text class="menu-title">支付订单</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>

        <!-- 投诉建议 -->
        <view class="menu-item" bindtap="goToComplaint">
            <view class="menu-left">
                <text class="menu-icon">📋</text>
                <text class="menu-title">投诉建议</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>

        <!-- 联系客服 -->
        <view class="menu-item" bindtap="callCustomerService">
            <view class="menu-left">
                <text class="menu-icon">💬</text>
                <text class="menu-title">联系客服</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>

        <!-- 意见反馈 -->
        <view class="menu-item" bindtap="goToFeedback">
            <view class="menu-left">
                <text class="menu-icon">📝</text>
                <text class="menu-title">意见反馈</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>

        <!-- 关于我们 -->
        <view class="menu-item" bindtap="goToAbout">
            <view class="menu-left">
                <text class="menu-icon">ℹ️</text>
                <text class="menu-title">关于我们</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>

        <!-- 设置 -->
        <view class="menu-item" bindtap="goToSettings">
            <view class="menu-left">
                <text class="menu-icon">⚙️</text>
                <text class="menu-title">设置</text>
            </view>
            <text class="menu-arrow">›</text>
        </view>
    </view>

    <!-- 退出登录按钮 -->
    <view class="logout-btn" bindtap="logout">
        <text>退出登录</text>
    </view>
</view>
